---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LxxComparison from '../../components/tools/LxxComparison';

const pageTitle = 'LXX Comparison';
const pageDescription = 'Parallel comparison of NT passages with their LXX citations';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="mb-8">
      <div class="text-5xl mb-4">📜</div>
      <h1 class="text-4xl font-bold text-slate-900 dark:text-white mb-2">
        LXX Comparison
      </h1>
      <p class="text-lg text-slate-600 dark:text-slate-400">
        Parallel comparison of NT passages with their LXX citations
      </p>
    </div>

    <LxxComparison client:load />
  </div>
</BaseLayout>
