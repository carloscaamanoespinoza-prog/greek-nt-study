---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TextualNotes from '../../components/tools/TextualNotes';

const pageTitle = 'Textual Notes';
const pageDescription = 'Simplified apparatus with key textual variants in the NT';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="mb-8">
      <div class="text-5xl mb-4">📝</div>
      <h1 class="text-4xl font-bold text-slate-900 dark:text-white mb-2">
        Textual Notes
      </h1>
      <p class="text-lg text-slate-600 dark:text-slate-400">
        Simplified apparatus with key textual variants in the NT
      </p>
    </div>

    <TextualNotes client:load />
  </div>
</BaseLayout>
