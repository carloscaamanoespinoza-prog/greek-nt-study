---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FrequencyMap from '../../components/tools/FrequencyMap';

const pageTitle = 'Vocabulary Frequency Map';
const pageDescription = 'Visualize the most common Greek NT words by frequency';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="mb-8">
      <div class="text-5xl mb-4">🔥</div>
      <h1 class="text-4xl font-bold text-slate-900 dark:text-white mb-2">
        Vocabulary Frequency Map
      </h1>
      <p class="text-lg text-slate-600 dark:text-slate-400">
        Visualize the most common Greek NT words by frequency
      </p>
    </div>

    <FrequencyMap client:load />
  </div>
</BaseLayout>
