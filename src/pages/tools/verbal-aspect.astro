---
import BaseLayout from '../../layouts/BaseLayout.astro';
import VerbalAspectChart from '../../components/tools/VerbalAspectChart';

const pageTitle = 'Verbal Aspect Chart';
const pageDescription = "Classify Greek verbs by Porter's aspect theory";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="mb-8">
      <div class="text-5xl mb-4">⚡</div>
      <h1 class="text-4xl font-bold text-slate-900 dark:text-white mb-2">
        Verbal Aspect Chart
      </h1>
      <p class="text-lg text-slate-600 dark:text-slate-400">
        Classify Greek verbs by Porter's aspect theory
      </p>
    </div>

    <VerbalAspectChart client:load />

    <div class="mt-12 p-6 bg-slate-100 dark:bg-slate-900 rounded-lg border border-slate-200 dark:border-slate-700">
      <h3 class="font-bold text-slate-900 dark:text-white mb-2">How to Use This Tool</h3>
      <ul class="text-slate-700 dark:text-slate-300 text-sm space-y-2">
        <li>
          <strong>Filter by Aspect:</strong> Click the aspect buttons to focus on Perfectivo (completed actions),
          Imperfectivo (ongoing processes), or Estativo (states of being)
        </li>
        <li>
          <strong>Search:</strong> Type to find verbs by Greek form, transliteration, or English meaning
        </li>
        <li>
          <strong>Examples:</strong> Each verb includes a real example from the Greek New Testament with verse reference
        </li>
        <li>
          <strong>Frequency:</strong> The rightmost column shows how many times each verb appears in the NT
        </li>
      </ul>
    </div>
  </div>
</BaseLayout>
