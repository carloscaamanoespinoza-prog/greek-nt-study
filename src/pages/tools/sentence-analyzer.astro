---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SentenceAnalyzer from '../../components/tools/SentenceAnalyzer';

const pageTitle = 'Sentence Analyzer';
const pageDescription = 'Color-coded grammatical analysis of Greek sentences';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="mb-8">
      <div class="text-5xl mb-4">🎨</div>
      <h1 class="text-4xl font-bold text-slate-900 dark:text-white mb-2">
        Sentence Analyzer
      </h1>
      <p class="text-lg text-slate-600 dark:text-slate-400">
        Color-coded grammatical analysis of Greek sentences
      </p>
    </div>

    <SentenceAnalyzer client:load />
  </div>
</BaseLayout>
