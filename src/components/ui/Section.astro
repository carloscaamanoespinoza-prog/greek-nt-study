---
interface Props {
  title: string;
  subtitle?: string;
  variant?: 'default' | 'accent' | 'gradient';
  children: any;
}

const { title, subtitle, variant = 'default', children } = Astro.props;

const variants = {
  default: 'bg-white dark:bg-slate-800',
  accent: 'bg-gradient-to-r from-slate-50 to-blue-50 dark:from-slate-800 dark:to-slate-700/50',
  gradient: 'bg-gradient-to-br from-academic-600 via-blue-600 to-cyan-600 text-white',
};

const titleColor = variant === 'gradient' ? 'text-white' : 'text-slate-900 dark:text-white';
const subtitleColor = variant === 'gradient' ? 'text-blue-100' : 'text-slate-600 dark:text-slate-400';
---

<section class={`${variants[variant]} py-16 sm:py-20 relative overflow-hidden`}>
  {variant === 'gradient' && (
    <div class="absolute inset-0 opacity-10 mix-blend-overlay pointer-events-none"
      style="background-image: url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="none" fill-rule="evenodd"%3E%3Cg fill="%23ffffff" fill-opacity="0.1"%3E%3Cpath d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');">
    </div>
  )}

  <div class="max-w-6xl mx-auto px-4 relative z-10">
    <div class="text-center mb-12 sm:mb-16">
      <h2 class={`text-3xl sm:text-4xl font-bold mb-3 ${titleColor}`}>
        {title}
      </h2>
      {subtitle && (
        <p class={`text-lg sm:text-xl ${subtitleColor}`}>
          {subtitle}
        </p>
      )}
    </div>

    <slot />
  </div>
</section>
