---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const pageTitle = 'Greek Grammar & Syntax';
const pageDescription = 'Learn 30 interactive lessons on Greek NT grammar with paradigm tables and quizzes';

// Get all lessons
const allLessons = await getCollection('grammar');

// Count lessons per module
const moduleCounts = {
  1: allLessons.filter(l => l.data.module === 1).length,
  2: allLessons.filter(l => l.data.module === 2).length,
  3: allLessons.filter(l => l.data.module === 3).length,
  4: allLessons.filter(l => l.data.module === 4).length,
};

const modules = [
  {
    num: 1,
    name: 'Foundations',
    description: 'Alphabet, accents, articles, all three declensions, adjectives, pronouns',
    icon: '🔤',
    color: 'from-blue-50 to-blue-100 dark:from-blue-900/20 dark:to-blue-800/20',
    borderColor: 'border-blue-300 dark:border-blue-700',
    lessons: moduleCounts[1],
  },
  {
    num: 2,
    name: 'Verb System',
    description: 'Present, imperfect, future, aorist, perfect tenses and all moods',
    icon: '⚡',
    color: 'from-amber-50 to-amber-100 dark:from-amber-900/20 dark:to-amber-800/20',
    borderColor: 'border-amber-300 dark:border-amber-700',
    lessons: moduleCounts[2],
  },
  {
    num: 3,
    name: 'Advanced Morphology',
    description: 'Participles, infinitives, μι-verbs, irregular forms, and contractions',
    icon: '🔬',
    color: 'from-green-50 to-green-100 dark:from-green-900/20 dark:to-green-800/20',
    borderColor: 'border-green-300 dark:border-green-700',
    lessons: moduleCounts[3],
  },
  {
    num: 4,
    name: 'Syntax',
    description: 'Genitive/dative uses, conditionals, verbal aspect, textual criticism',
    icon: '📖',
    color: 'from-red-50 to-red-100 dark:from-red-900/20 dark:to-red-800/20',
    borderColor: 'border-red-300 dark:border-red-700',
    lessons: moduleCounts[4],
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    {/* Header */}
    <div class="text-center mb-12">
      <h1 class="text-5xl font-bold text-slate-900 dark:text-white mb-4">
        Greek Grammar & Syntax
      </h1>
      <p class="text-xl text-slate-600 dark:text-slate-400 mb-6">
        30 interactive lessons with real NT examples, paradigm tables, and adaptive quizzes
      </p>
      <div class="flex items-center justify-center gap-8 text-slate-700 dark:text-slate-300">
        <div class="text-center">
          <div class="text-3xl font-bold text-blue-600 dark:text-blue-400">{allLessons.length}</div>
          <div class="text-sm font-semibold">Total Lessons</div>
        </div>
        <div class="w-px h-12 bg-slate-300 dark:bg-slate-700"></div>
        <div class="text-center">
          <div class="text-3xl font-bold text-green-600 dark:text-green-400">6</div>
          <div class="text-sm font-semibold">Paradigm Tables</div>
        </div>
        <div class="w-px h-12 bg-slate-300 dark:bg-slate-700"></div>
        <div class="text-center">
          <div class="text-3xl font-bold text-amber-600 dark:text-amber-400">3</div>
          <div class="text-sm font-semibold">Quiz Modes</div>
        </div>
      </div>
    </div>

    {/* Module Cards */}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
      {modules.map((module) => (
        <a
          href={`/grammar/lessons/${String(module.num).padStart(2, '0')}-`}
          class={`group p-6 rounded-lg border-2 ${module.borderColor} bg-gradient-to-br ${module.color} hover:shadow-lg hover:scale-105 transition-all`}
        >
          <div class="flex items-start justify-between mb-4">
            <div class="text-4xl">{module.icon}</div>
            <div class="text-right">
              <div class="text-sm font-bold text-slate-600 dark:text-slate-400">
                Module {module.num}
              </div>
              <div class="text-2xl font-bold text-slate-900 dark:text-white">
                {module.lessons}
              </div>
              <div class="text-xs text-slate-600 dark:text-slate-400">lessons</div>
            </div>
          </div>

          <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
            {module.name}
          </h3>

          <p class="text-slate-700 dark:text-slate-300 mb-4">
            {module.description}
          </p>

          <div class="flex items-center text-blue-600 dark:text-blue-400 font-semibold group-hover:translate-x-2 transition-transform">
            Start Module →
          </div>
        </a>
      ))}
    </div>

    {/* Learning Path */}
    <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-8 mb-12">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">
        Recommended Learning Path
      </h2>
      <div class="space-y-4">
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold text-sm">
            1
          </div>
          <div>
            <h3 class="font-bold text-slate-900 dark:text-white">
              Start with Module I: Foundations
            </h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm">
              Learn the building blocks: alphabet, accents, articles, and the three declensions.
            </p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-amber-600 text-white flex items-center justify-center font-bold text-sm">
            2
          </div>
          <div>
            <h3 class="font-bold text-slate-900 dark:text-white">
              Master Module II: Verb System
            </h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm">
              Understand Greek tenses, moods, and voice. This is critical for reading the NT.
            </p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-green-600 text-white flex items-center justify-center font-bold text-sm">
            3
          </div>
          <div>
            <h3 class="font-bold text-slate-900 dark:text-white">
              Advance to Module III: Advanced Morphology
            </h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm">
              Handle complex forms: participles, infinitives, and irregular verbs.
            </p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-red-600 text-white flex items-center justify-center font-bold text-sm">
            4
          </div>
          <div>
            <h3 class="font-bold text-slate-900 dark:text-white">
              Complete with Module IV: Syntax
            </h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm">
              Learn how forms function in sentences. Apply all previous knowledge to real NT passages.
            </p>
          </div>
        </div>
      </div>
    </div>

    {/* Quick Start Button */}
    <div class="text-center">
      <a
        href="/grammar/lessons/01-alphabet"
        class="inline-block px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg transition-colors text-lg"
      >
        Start with Lesson 1: The Greek Alphabet →
      </a>
    </div>
  </div>
</BaseLayout>
