---
// Base layout for all pages
// Includes header, fonts, meta tags

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'Greek NT Study - Κοινή Γραμματική',
  description = 'Interactive study platform for Greek New Testament with morphological analysis and lexicon',
  canonical = Astro.url.href
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Greek Typography Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Cardo:ital@0;1&family=GFS+Didot&display=swap" rel="stylesheet" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Title -->
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />

    <!-- Theme Color -->
    <meta name="theme-color" content="#1f4e79" />
  </head>

  <body class="bg-white dark:bg-slate-950 text-slate-900 dark:text-slate-100">
    <!-- Navigation -->
    <nav class="sticky top-0 z-50 bg-white/95 dark:bg-slate-900/95 backdrop-blur-md border-b border-slate-200/50 dark:border-slate-800/50 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="group flex items-center gap-2 hover:opacity-80 transition-opacity">
          <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-gradient-to-br from-academic-600 to-blue-600">
            <span class="font-greek text-lg font-bold text-white">Κ</span>
          </div>
          <span class="font-greek text-xl font-bold text-slate-900 dark:text-white hidden sm:inline">Κοινή</span>
        </a>

        <!-- Navigation Links -->
        <div class="flex items-center gap-6 sm:gap-8">
          <a href="/reader/matthew/1" class="text-sm font-medium text-slate-700 dark:text-slate-300 hover:text-academic-600 dark:hover:text-academic-400 transition-colors relative group">
            Reader
            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-gradient-to-r from-academic-600 to-blue-600 group-hover:w-full transition-all duration-300"></span>
          </a>
          <a href="/grammar" class="text-sm font-medium text-slate-700 dark:text-slate-300 hover:text-academic-600 dark:hover:text-academic-400 transition-colors relative group">
            Grammar
            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-gradient-to-r from-academic-600 to-blue-600 group-hover:w-full transition-all duration-300"></span>
          </a>
          <a href="/search" class="text-sm font-medium text-slate-700 dark:text-slate-300 hover:text-academic-600 dark:hover:text-academic-400 transition-colors relative group">
            Search
            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-gradient-to-r from-academic-600 to-blue-600 group-hover:w-full transition-all duration-300"></span>
          </a>
          <a href="/tools" class="text-sm font-medium text-slate-700 dark:text-slate-300 hover:text-academic-600 dark:hover:text-academic-400 transition-colors relative group">
            Tools
            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-gradient-to-r from-academic-600 to-blue-600 group-hover:w-full transition-all duration-300"></span>
          </a>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="min-h-[calc(100vh-60px)]">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 py-6">
      <div class="max-w-7xl mx-auto px-4 text-center text-sm text-slate-600 dark:text-slate-400">
        <p>Greek NT Study App • Interactive Learning Platform</p>
        <p class="mt-2 text-xs">Data sources: OpenGNT, Strong's Dictionary, STEPBible Lexicons</p>
      </div>
    </footer>

    <style is:global>
      :root {
        --font-greek: 'Cardo', 'GFS Didot', serif;
        --font-serif: 'Merriweather', serif;
        --font-sans: 'Inter', sans-serif;
      }

      * {
        @apply transition-colors duration-200;
      }

      body {
        font-family: var(--font-sans);
      }

      .font-greek {
        font-family: var(--font-greek);
      }

      /* Greek text styling */
      .greek-text {
        font-family: var(--font-greek);
        font-size: 1.1em;
        line-height: 1.8;
        letter-spacing: 0.02em;
      }

      /* Word styling for interactivity */
      .greek-word {
        cursor: pointer;
        padding: 0.125em 0.25em;
        border-radius: 0.25em;
        transition: all 0.2s ease;
        position: relative;
      }

      .greek-word:hover {
        background-color: rgba(63, 70, 230, 0.15);
        text-decoration: underline;
        transform: scale(1.02);
      }

      .greek-word.active {
        background-color: rgba(63, 70, 230, 0.25);
        box-shadow: 0 0 0 2px rgb(63, 70, 230);
        font-weight: 600;
      }

      /* Smooth scrolling */
      html {
        scroll-behavior: smooth;
      }

      /* Selection styling */
      ::selection {
        background-color: rgba(63, 70, 230, 0.3);
        color: inherit;
      }

      ::-moz-selection {
        background-color: rgba(63, 70, 230, 0.3);
        color: inherit;
      }

      /* Scrollbar styling */
      ::-webkit-scrollbar {
        width: 10px;
      }

      ::-webkit-scrollbar-track {
        background: transparent;
      }

      ::-webkit-scrollbar-thumb {
        background: rgba(100, 116, 139, 0.5);
        border-radius: 5px;
      }

      ::-webkit-scrollbar-thumb:hover {
        background: rgba(100, 116, 139, 0.8);
      }

      /* Print styles */
      @media print {
        nav,
        footer {
          display: none;
        }
      }
    </style>
  </body>
</html>
