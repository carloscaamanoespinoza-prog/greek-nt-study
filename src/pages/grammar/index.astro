---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
import Section from '../../components/ui/Section.astro';
import { getCollection } from 'astro:content';

const pageTitle = 'Greek Grammar & Syntax';
const pageDescription = 'Learn 30 interactive lessons on Greek NT grammar with paradigm tables and quizzes';

// Get all lessons
const allLessons = await getCollection('grammar');

// Count lessons per module
const moduleCounts = {
  1: allLessons.filter(l => l.data.module === 1).length,
  2: allLessons.filter(l => l.data.module === 2).length,
  3: allLessons.filter(l => l.data.module === 3).length,
  4: allLessons.filter(l => l.data.module === 4).length,
};

const modules = [
  {
    num: 1,
    name: 'Foundations',
    description: 'Alphabet, accents, articles, all three declensions, adjectives, pronouns',
    icon: '🔤',
    color: 'from-blue-50 to-blue-100 dark:from-blue-900/20 dark:to-blue-800/20',
    borderColor: 'border-blue-300 dark:border-blue-700',
    lessons: moduleCounts[1],
  },
  {
    num: 2,
    name: 'Verb System',
    description: 'Present, imperfect, future, aorist, perfect tenses and all moods',
    icon: '⚡',
    color: 'from-amber-50 to-amber-100 dark:from-amber-900/20 dark:to-amber-800/20',
    borderColor: 'border-amber-300 dark:border-amber-700',
    lessons: moduleCounts[2],
  },
  {
    num: 3,
    name: 'Advanced Morphology',
    description: 'Participles, infinitives, μι-verbs, irregular forms, and contractions',
    icon: '🔬',
    color: 'from-green-50 to-green-100 dark:from-green-900/20 dark:to-green-800/20',
    borderColor: 'border-green-300 dark:border-green-700',
    lessons: moduleCounts[3],
  },
  {
    num: 4,
    name: 'Syntax',
    description: 'Genitive/dative uses, conditionals, verbal aspect, textual criticism',
    icon: '📖',
    color: 'from-red-50 to-red-100 dark:from-red-900/20 dark:to-red-800/20',
    borderColor: 'border-red-300 dark:border-red-700',
    lessons: moduleCounts[4],
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <!-- Header Section -->
  <Section title="Greek Grammar & Syntax" subtitle="Master the structure of biblical Greek through 30 interactive lessons">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-12">
      <div class="bg-white dark:bg-slate-800 rounded-lg p-6 shadow-card text-center">
        <div class="text-4xl font-bold text-academic-600 dark:text-academic-400 mb-2">
          {allLessons.length}
        </div>
        <div class="text-slate-600 dark:text-slate-400 font-semibold">
          Total Lessons
        </div>
      </div>
      <div class="bg-white dark:bg-slate-800 rounded-lg p-6 shadow-card text-center">
        <div class="text-4xl font-bold text-green-600 dark:text-green-400 mb-2">
          6
        </div>
        <div class="text-slate-600 dark:text-slate-400 font-semibold">
          Paradigm Tables
        </div>
      </div>
      <div class="bg-white dark:bg-slate-800 rounded-lg p-6 shadow-card text-center">
        <div class="text-4xl font-bold text-amber-600 dark:text-amber-400 mb-2">
          3
        </div>
        <div class="text-slate-600 dark:text-slate-400 font-semibold">
          Quiz Modes
        </div>
      </div>
    </div>
  </Section>

  <!-- Module Cards -->
  <div class="bg-white dark:bg-slate-800">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-20">
      <h2 class="text-3xl sm:text-4xl font-bold mb-12 text-center text-slate-900 dark:text-white">
        Learning Modules
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {modules.map((module) => (
          <a
            href={`/grammar/lessons/${String(module.num).padStart(2, '0')}-`}
            class={`group relative overflow-hidden rounded-xl border-2 ${module.borderColor} bg-gradient-to-br ${module.color} p-8 transition-all hover:shadow-card-hover hover:-translate-y-2`}
          >
            <div class="relative z-10">
              <div class="flex items-start justify-between mb-6">
                <div class="text-5xl">{module.icon}</div>
                <div class="text-right">
                  <div class="text-xs font-bold uppercase text-slate-600 dark:text-slate-400 tracking-wider">
                    Module {module.num}
                  </div>
                  <div class="text-3xl font-bold text-slate-900 dark:text-white">
                    {module.lessons}
                  </div>
                  <div class="text-xs text-slate-600 dark:text-slate-400">lessons</div>
                </div>
              </div>

              <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-3 group-hover:text-academic-600 dark:group-hover:text-academic-400 transition-colors">
                {module.name}
              </h3>

              <p class="text-slate-700 dark:text-slate-300 mb-6 leading-relaxed">
                {module.description}
              </p>

              <div class="flex items-center gap-2 text-academic-600 dark:text-academic-400 font-semibold group-hover:translate-x-2 transition-transform">
                <span>Start Module</span>
                <span>→</span>
              </div>
            </div>

            <!-- Bottom accent -->
            <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-academic-400 via-blue-500 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Learning Path Section -->
  <Section title="Recommended Learning Path" subtitle="Follow this sequence for optimal learning" variant="accent">
    <div class="max-w-3xl mx-auto">
      <div class="space-y-6">
        <div class="flex gap-6">
          <div class="flex-shrink-0">
            <div class="flex items-center justify-center h-12 w-12 rounded-full bg-gradient-to-br from-academic-600 to-blue-600 text-white font-bold">
              1
            </div>
          </div>
          <div class="flex-grow">
            <h3 class="text-lg font-bold mb-2 text-slate-900 dark:text-white">
              Module I: Foundations
            </h3>
            <p class="text-slate-600 dark:text-slate-400">
              Learn the building blocks: alphabet, accents, articles, and the three declensions. These fundamentals are essential for everything that follows.
            </p>
          </div>
        </div>

        <div class="flex gap-6">
          <div class="flex-shrink-0">
            <div class="flex items-center justify-center h-12 w-12 rounded-full bg-gradient-to-br from-amber-600 to-orange-600 text-white font-bold">
              2
            </div>
          </div>
          <div class="flex-grow">
            <h3 class="text-lg font-bold mb-2 text-slate-900 dark:text-white">
              Module II: Verb System
            </h3>
            <p class="text-slate-600 dark:text-slate-400">
              Master Greek tenses, moods, and voice. This is critical for reading the NT and understanding how actions are conveyed in the text.
            </p>
          </div>
        </div>

        <div class="flex gap-6">
          <div class="flex-shrink-0">
            <div class="flex items-center justify-center h-12 w-12 rounded-full bg-gradient-to-br from-green-600 to-emerald-600 text-white font-bold">
              3
            </div>
          </div>
          <div class="flex-grow">
            <h3 class="text-lg font-bold mb-2 text-slate-900 dark:text-white">
              Module III: Advanced Morphology
            </h3>
            <p class="text-slate-600 dark:text-slate-400">
              Handle complex forms: participles, infinitives, μι-verbs, irregular verbs, and contractions. These advanced structures are common in the NT.
            </p>
          </div>
        </div>

        <div class="flex gap-6">
          <div class="flex-shrink-0">
            <div class="flex items-center justify-center h-12 w-12 rounded-full bg-gradient-to-br from-red-600 to-rose-600 text-white font-bold">
              4
            </div>
          </div>
          <div class="flex-grow">
            <h3 class="text-lg font-bold mb-2 text-slate-900 dark:text-white">
              Module IV: Syntax
            </h3>
            <p class="text-slate-600 dark:text-slate-400">
              Learn how forms function in sentences. Apply all previous knowledge to real NT passages and develop deep comprehension of the text.
            </p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-12 flex flex-col sm:flex-row gap-4 justify-center">
      <Button href="/grammar/lessons/01-alphabet" variant="primary" size="lg">
        📖 Start Lesson 1
      </Button>
      <Button href="/reader" variant="outline" size="lg">
        📖 Go to Reader
      </Button>
    </div>
  </Section>
</BaseLayout>
