---
// Base layout for all pages
// Includes header, fonts, meta tags

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'Greek NT Study - Κοινή Γραμματική',
  description = 'Interactive study platform for Greek New Testament with morphological analysis and lexicon',
  canonical = Astro.url.href
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Greek Typography Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Cardo:ital@0;1&family=GFS+Didot&display=swap" rel="stylesheet" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Title -->
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />

    <!-- Theme Color -->
    <meta name="theme-color" content="#1f4e79" />
  </head>

  <body class="bg-white dark:bg-slate-950 text-slate-900 dark:text-slate-100">
    <!-- Navigation -->
    <nav class="sticky top-0 z-50 bg-white/95 dark:bg-slate-950/95 backdrop-blur border-b border-slate-200 dark:border-slate-800">
      <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="font-greek text-2xl font-bold text-blue-900 dark:text-blue-300 hover:text-blue-700">
          Κοινή
        </a>

        <div class="flex items-center gap-4">
          <a href="/reader/matthew/1" class="text-sm font-medium hover:text-blue-600 dark:hover:text-blue-400">
            Reader
          </a>
          <a href="/grammar" class="text-sm font-medium hover:text-blue-600 dark:hover:text-blue-400">
            Grammar
          </a>
          <a href="/search" class="text-sm font-medium hover:text-blue-600 dark:hover:text-blue-400">
            Search
          </a>
          <a href="/tools" class="text-sm font-medium hover:text-blue-600 dark:hover:text-blue-400">
            Tools
          </a>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="min-h-[calc(100vh-60px)]">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 py-6">
      <div class="max-w-7xl mx-auto px-4 text-center text-sm text-slate-600 dark:text-slate-400">
        <p>Greek NT Study App • Interactive Learning Platform</p>
        <p class="mt-2 text-xs">Data sources: OpenGNT, Strong's Dictionary, STEPBible Lexicons</p>
      </div>
    </footer>

    <style is:global>
      :root {
        --font-greek: 'Cardo', 'GFS Didot', serif;
        --font-serif: 'Merriweather', serif;
        --font-sans: 'Inter', sans-serif;
      }

      body {
        font-family: var(--font-sans);
      }

      .font-greek {
        font-family: var(--font-greek);
      }

      /* Greek text styling */
      .greek-text {
        font-family: var(--font-greek);
        font-size: 1.1em;
        line-height: 1.8;
      }

      /* Word styling for interactivity */
      .greek-word {
        cursor: pointer;
        padding: 0.125em 0.25em;
        border-radius: 0.25em;
        transition: background-color 0.2s ease;
      }

      .greek-word:hover {
        background-color: rgba(59, 130, 246, 0.1);
        text-decoration: underline;
      }

      .greek-word.active {
        background-color: rgba(59, 130, 246, 0.2);
        box-shadow: 0 0 0 1px rgb(59, 130, 246);
      }

      /* Smooth scrolling */
      html {
        scroll-behavior: smooth;
      }

      /* Print styles */
      @media print {
        nav,
        footer {
          display: none;
        }
      }
    </style>
  </body>
</html>
