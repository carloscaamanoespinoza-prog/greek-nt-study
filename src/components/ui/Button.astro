---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  children: any;
  class?: string;
}

const { href, variant = 'primary', size = 'md', children, class: className = '' } = Astro.props;

const baseStyles = 'inline-flex items-center justify-center font-semibold transition-all duration-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-academic-500';

const variants = {
  primary: 'bg-gradient-to-r from-academic-600 to-blue-600 text-white hover:from-academic-700 hover:to-blue-700 shadow-md hover:shadow-glow active:scale-95',
  secondary: 'bg-slate-100 dark:bg-slate-700 text-slate-900 dark:text-white hover:bg-slate-200 dark:hover:bg-slate-600 active:scale-95',
  outline: 'border-2 border-academic-400 text-academic-600 dark:text-academic-300 hover:bg-academic-50 dark:hover:bg-academic-900/20 active:scale-95',
};

const sizes = {
  sm: 'px-4 py-2 text-sm gap-2',
  md: 'px-6 py-3 text-base gap-3',
  lg: 'px-8 py-4 text-lg gap-3',
};
---

<a href={href} class={`${baseStyles} ${variants[variant]} ${sizes[size]} ${className}`}>
  <slot />
</a>
