---
// Layout for the Greek text reader
// Includes sidebar navigation and main text area

import BaseLayout from './BaseLayout.astro';

export interface Props {
  title?: string;
  book?: string;
  chapter?: number;
}

const { title = 'Reader', book, chapter } = Astro.props;
---

<BaseLayout title={title}>
  <div class="flex h-[calc(100vh-60px)]">
    <!-- Sidebar Navigation -->
    <aside class="w-64 border-r border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 overflow-y-auto">
      <div class="p-4 sticky top-0 bg-slate-50 dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800">
        <h2 class="font-bold text-lg mb-4">Books</h2>
        <div id="book-selector" class="space-y-2">
          <a href="/reader/matthew/1" class:list={[
            "block px-3 py-2 rounded text-sm hover:bg-blue-100 dark:hover:bg-blue-900/30",
            { "bg-blue-100 dark:bg-blue-900/30 font-bold": book === 'matthew' }
          ]}>
            Matthew
          </a>
          <a href="/reader/mark/1" class:list={[
            "block px-3 py-2 rounded text-sm hover:bg-blue-100 dark:hover:bg-blue-900/30",
            { "bg-blue-100 dark:bg-blue-900/30 font-bold": book === 'mark' }
          ]}>
            Mark
          </a>
          <a href="/reader/luke/1" class:list={[
            "block px-3 py-2 rounded text-sm hover:bg-blue-100 dark:hover:bg-blue-900/30",
            { "bg-blue-100 dark:bg-blue-900/30 font-bold": book === 'luke' }
          ]}>
            Luke
          </a>
          <a href="/reader/john/1" class:list={[
            "block px-3 py-2 rounded text-sm hover:bg-blue-100 dark:hover:bg-blue-900/30",
            { "bg-blue-100 dark:bg-blue-900/30 font-bold": book === 'john' }
          ]}>
            John
          </a>
          <a href="/reader/acts/1" class:list={[
            "block px-3 py-2 rounded text-sm hover:bg-blue-100 dark:hover:bg-blue-900/30",
            { "bg-blue-100 dark:bg-blue-900/30 font-bold": book === 'acts' }
          ]}>
            Acts
          </a>
          <a href="/reader/romans/1" class:list={[
            "block px-3 py-2 rounded text-sm hover:bg-blue-100 dark:hover:bg-blue-900/30",
            { "bg-blue-100 dark:bg-blue-900/30 font-bold": book === 'romans' }
          ]}>
            Romans
          </a>
          <!-- More books can be added here -->
        </div>
      </div>

      <div id="chapter-list" class="p-4 space-y-1">
        <!-- Chapters will be populated dynamically -->
      </div>
    </aside>

    <!-- Main Content Area -->
    <main class="flex-1 overflow-y-auto p-8">
      <slot />
    </main>
  </div>

  <style is:global>
    /* Ensure layout fills viewport -->
    html, body {
      height: 100%;
      margin: 0;
      padding: 0;
    }
  </style>

  <script>
    // Populate chapter list based on book
    const book = document.location.pathname.split('/')[3];
    const chapter = document.location.pathname.split('/')[4];

    // Book chapter counts
    const bookChapters: { [key: string]: number } = {
      matthew: 28,
      mark: 16,
      luke: 24,
      john: 21,
      acts: 28,
      romans: 16,
      '1-corinthians': 16,
      '2-corinthians': 13,
      galatians: 6,
      ephesians: 6,
      philippians: 4,
      colossians: 4,
      '1-thessalonians': 5,
      '2-thessalonians': 3,
      '1-timothy': 6,
      '2-timothy': 4,
      titus: 3,
      philemon: 1,
      hebrews: 13,
      james: 5,
      '1-peter': 5,
      '2-peter': 3,
      '1-john': 5,
      '2-john': 1,
      '3-john': 1,
      jude: 1,
      revelation: 22,
    };

    if (book && bookChapters[book]) {
      const chapterList = document.getElementById('chapter-list');
      const numChapters = bookChapters[book];

      let html = '<div class="font-bold text-sm text-slate-600 dark:text-slate-400 mb-2">Chapters</div>';
      for (let i = 1; i <= numChapters; i++) {
        const isActive = parseInt(chapter) === i;
        html += `
          <a href="/reader/${book}/${i}"
             class="block px-3 py-2 text-sm rounded hover:bg-blue-100 dark:hover:bg-blue-900/30 ${
               isActive ? 'bg-blue-100 dark:bg-blue-900/30 font-bold' : ''
             }">
            Ch. ${i}
          </a>
        `;
      }
      if (chapterList) {
        chapterList.innerHTML = html;
      }
    }
  </script>
</BaseLayout>
